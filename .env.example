# Contact form – use one of the two options below.
# Copy this file to .env.local and fill in your values. Never commit .env.local.
# All site forms (including Zambia /get-started, /contact-sales, experience page) POST to POST /api/contact.

# Option 1: Resend (one API key). If Resend fails, the API tries SMTP below when configured.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_RECIPIENT_EMAIL=info@mr-otp.com
# RESEND_FROM=Mr OTP <noreply@your-verified-domain.com>

# Option 2: SMTP (e.g. Hostinger) – sender & recipient for contact form
# Hostinger Email – use smtp.hostinger.com (not Titan)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=wleads@mr-otp.com
SMTP_PASS=Mrotp@2024
CONTACT_DEBUG=true
CONTACT_RECIPIENT_EMAIL=info@mr-otp.com
MAIL_FROM="Mr OTP Website <wleads@mr-otp.com>"
CONTACT_DEBUG=true

# Optional (helps on some hosts / TLS issues)
# SMTP_FAMILY=4
# SMTP_TLS_REJECT_UNAUTHORIZED=false
#
# CONTACT_DEBUG=true → API error JSON includes a `debug` object with the real SMTP/API error.
# Use only while troubleshooting; remove or set false on public production.
#
# Deployed site (Vercel, etc.): add the same SMTP_* (or RESEND_*) vars in the host’s Environment
# Variables UI — .env.local is not uploaded on git push.
